# Public app URL (production domain on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Add `${NEXT_PUBLIC_APP_URL}/auth/callback` in Supabase Dashboard → Authentication → URL configuration → Redirect URLs
# (needed for email confirmation, signup redirect, and password recovery links; not a new env var in Supabase)

# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform fee percentage taken from ticket gross (for host net previews + checkout metadata)
NEXT_PUBLIC_PLATFORM_FEE_PERCENT=10

# Mapbox (Geocoding API: create a public token at https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Country filter for autocomplete (ISO 3166-1 alpha-2). Unset defaults to `us` so global noise (e.g. Argentina) is reduced.
# Set to `world`, `off`, or `global` to disable the country filter for international-first deployments.
NEXT_PUBLIC_MAPBOX_GEOCODING_COUNTRY=

# Resend (https://resend.com) — server-side API for transactional mail from this app:
#   contact form, host welcome (after onboarding), ticket QR receipt (after Stripe checkout).
# Signup verification / password reset / magic links are sent by Supabase Auth. To route those through Resend,
# set Custom SMTP in Supabase Dashboard → Authentication → SMTP (Resend provides SMTP host + credentials in their docs).
RESEND_API_KEY=
# Optional verified sender, e.g. "RAGE <hello@rage.events>" — must match a verified domain in Resend.
RESEND_FROM_EMAIL=
# Inbox that receives contact form submissions (defaults to ragesupportpage@gmail.com if unset).
RESEND_SUPPORT_INBOX=

# Vercel Cron: GET /api/cron/* with Authorization: Bearer <CRON_SECRET>
# Schedules in vercel.json are UTC. Default `25 4 * * *` ≈ 9:25 PM America/Los_Angeles during daylight saving (PDT).
# For the same local clock time during Pacific Standard Time (winter), use `25 5 * * *` instead.
# Reminds users who signed up but have not confirmed email (Resend). Per-user cooldown + max sends.
CRON_SECRET=
# Minimum hours between reminders for the same unverified user (default 48).
REGISTRATION_REMINDER_COOLDOWN_HOURS=48
# Max reminder emails per user while still unverified (default 5).
REGISTRATION_REMINDER_MAX=5

# Create-event nudges: all registered users (non-anonymous with email, Resend). Default cooldown 7 days.
CREATE_EVENT_REMINDER_COOLDOWN_HOURS=168
CREATE_EVENT_REMINDER_MAX=6
